// Court of Apil Pickleball Hub — Database schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BookingStatus {
  PENDING   // awaiting admin approval of proof of payment
  CONFIRMED // approved, confirmation email sent
  REJECTED  // proof of payment rejected / invalid
  CANCELLED // cancelled by admin
}

enum PaymentMethod {
  GCASH
  MAYA
  BPI
}

// One row per booking "order" — can cover multiple hourly slots in one day
model Booking {
  id                String        @id @default(cuid())
  customerName      String        @default("")
  contactNumber     String        @default("")
  email             String        @default("")
  date              DateTime      @default(now())
  startHours        Int[]
  courtTotal        Int           @default(0)
  rentalTotal       Int           @default(0)
  grandTotal        Int           @default(0)
  paddleCount       Int           @default(0)
  paymentMethod     PaymentMethod @default(GCASH)
  referenceNumber   String        @default("")
  amountSent        Int           @default(0)
  proofOfPaymentUrl String        @default("")
  status            BookingStatus @default(PENDING)
  adminNote         String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now()) @updatedAt

  slots             Slot[]
}

// One row per individual hour claimed on the calendar. Used by the schedule
// grid to look up per-hour availability and to enforce that the same
// date+hour can't be double-booked.
model Slot {
  id        String   @id @default(cuid())
  date      DateTime
  hour      Int
  bookingId String

  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([date, hour])
}

// Payment accounts (GCash/Maya/BPI) shown to customers at checkout,
// managed by the admin from the "Payment accounts" tab.
model PaymentAccount {
  id            String        @id @default(cuid())
  method        PaymentMethod
  accountName   String
  accountNumber String
  qrImageUrl    String?
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt
}
