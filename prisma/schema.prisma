// Court of Apil Pickleball Hub — Database schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BookingStatus {
  PENDING   // awaiting admin approval of proof of payment
  CONFIRMED // approved, confirmation email sent
  REJECTED  // proof of payment rejected / invalid
  CANCELLED // cancelled by admin
}

enum PaymentMethod {
  GCASH
  MAYA
  BPI
}

// One row per booking "order" — can cover multiple hourly slots in one day
model Booking {
  id                String        @id @default(cuid())
  customerName      String        @default("")
  contactNumber     String        @default("")
  email             String        @default("")
  date              DateTime      @default(now())
  startHours        Int[]
  courtTotal        Int           @default(0)
  rentalTotal       Int           @default(0)
  grandTotal        Int           @default(0)
  paddleCount       Int           @default(0)
  paymentMethod     PaymentMethod @default(GCASH)
  referenceNumber   String        @default("")
  amountSent        Int           @default(0)
  proofOfPaymentUrl String        @default("")
  status            BookingStatus @default(PENDING)
  adminNote         String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now()) @updatedAt

  slots             Slot[]
}

// One row per individual hour claimed on the calendar. Used by the schedule
// grid to look up per-hour availability and to enforce that the same
// date+hour can't be double-booked.
model Slot {
  id        String   @id @default(cuid())
  date      DateTime
  hour      Int
  bookingId String

  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([date, hour])
}

// Payment accounts (GCash/Maya/BPI) shown to customers at checkout,
// managed by the admin from the "Payment accounts" tab.
model PaymentAccount {
  id            String        @id @default(cuid())
  method        PaymentMethod
  accountName   String
  accountNumber String
  qrImageUrl    String?
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt
}

// Homepage hero carousel slides. Not yet wired into any page — this is a
// minimal placeholder shape (image + optional text/link + ordering) so the
// API route compiles. Adjust field names freely once the actual slider UI
// is built, since nothing currently depends on these fields.
model HeroSlide {
  id        String   @id @default(cuid())
  imageUrl  String
  headline  String?
  subtext   String?
  linkUrl   String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

// Singleton row holding admin-editable court & rental pricing. Always
// looked up/created via the fixed id "singleton" in getPricingSettings().
model PricingSettings {
  id                String @id @default("singleton")
  weekdayDayPrice   Int    @default(200)
  weekdayNightPrice Int    @default(250)
  weekendPrice      Int    @default(250)
  rental1Price      Int    @default(100)
  rental2Price      Int    @default(150)
}

// Singleton row holding everything the admin can customize about the site's
// look and copy without touching code: branding (name/tagline/logo), the
// brand color palette (applied site-wide via CSS variables), and the text
// shown in the hero, about, and footer sections of the homepage. Always
// looked up/created via the fixed id "singleton" in getSiteSettings().
model SiteSettings {
  id      String  @id @default("singleton")

  // Branding
  siteName    String  @default("Court of Apil")
  siteTagline String  @default("Pickleball Hub")
  logoUrl     String?

  // Brand colors (hex). Applied globally via CSS variables so the whole
  // site's palette updates without a code change or rebuild.
  colorOrange      String @default("#F46036")
  colorOrangeDark  String @default("#D6491F")
  colorOrangeLight String @default("#FF8C61")
  colorBlue        String @default("#6CD4FF")
  colorBlueDark    String @default("#2FA8D9")
  colorBlueLight   String @default("#C7EEFF")
  colorInk         String @default("#173A45")
  colorCream       String @default("#FBF8F3")

  // Hero section copy
  heroBadgeText           String @default("Open 24/7 · Talisay City, Cebu")
  heroHeadlineLine1       String @default("Court of Apil")
  heroHeadlineLine2       String @default("Pickleball Hub")
  heroSubtext             String @default("An exclusive outdoor pickleball court in Talisay City, Cebu — open around the clock, with paddle & ball rentals on-site and free parking for every player.")
  heroPrimaryButtonText   String @default("Book a slot")
  heroSecondaryButtonText String @default("See pricing")
  heroCardTitle           String @default("Rentals available")
  heroCardSubtitle        String @default("Paddles & balls on-site")

  // About section copy
  aboutHeading String @default("About the court")
  aboutText    String @default("Court of Apil is an exclusive outdoor pickleball court located in Talisay City, Cebu. The facility is open 24/7 and offers paddle and ball rentals, with free parking available for players.")
  aboutBullets String @default("Outdoor court, open every day, all day\nPaddle & ball rental available on-site\nFree parking for all players\nLocated in Talisay City, Cebu")

  // Footer copy
  footerTagline      String @default("An exclusive outdoor pickleball court in Talisay City, Cebu. Open 24/7, with paddle & ball rentals and free parking.")
  footerLocationText String @default("Talisay City, Cebu, Philippines")
  footerMapUrl       String @default("https://maps.app.goo.gl/5cj5BP3vJSMy94p48?g_st=afm")
  footerHoursText    String @default("Open 24 hours a day, every day.")

  updatedAt DateTime @default(now()) @updatedAt
}
